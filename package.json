        "@angular/forms": "^21.2.0",
        "@angular/material": "^21.2.14",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "@maplibre/ngx-maplibre-gl": "21.0.2",
        "@ngxs/store": "^21.0.0",
        "@types/lodash": "^4.17.24",
        "lodash": "^4.18.1",
        "maplibre-gl": "5.24.0",
        "rxjs": "~7.8.0",
        "showdown": "2.1.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.15",
